# Copy to deploy/.env and fill in. Never commit deploy/.env.
# These vars get pasted into the Akash Console when deploying scale2.sdl.yml.

# Strong SSH password — required, fail-closed.
# Generate: openssl rand -base64 24
SSH_PASSWORD=

# HuggingFace read token. Public BeIR/msmarco datasets work without it
# but HF rate-limits anonymous downloads of the 8.84M corpus.
HUGGING_FACE_HUB_TOKEN=

# Optional. Leave blank to disable Weights & Biases logging.
WANDB_API_KEY=
WANDB_PROJECT=drt-scale2

# Git repo containing drt/ — the Akash container clones from here.
# Use a public HTTPS URL or set up a deploy key for private repos.
DRT_REPO_URL=https://github.com/your-user/drt.git
DRT_REPO_REF=main
